    {
      "id": "ecommerce.CartDrawer",
      "name": "CartDrawer",
      "description": "Slide-out cart panel that overlays the page. Displays cart items with quantity controls, remove actions, and a checkout button.",
      "whenToUse": "Use as the primary cart interface that slides in from the side when a user adds an item or clicks the cart icon. Ideal for ecommerce sites that want a non-disruptive cart experience without navigating away from the current page.",
      "isShell": false,
      "props": [
        { "name": "items", "type": "CartItem[]", "required": true, "default": null, "description": "Array of cart items: {id, title, image, price, qty, variant?}" },
        { "name": "currency", "type": "Currency", "required": false, "default": "\"USD\"", "description": "Currency code for formatting prices: \"USD\" | \"INR\" | \"EUR\" | \"GBP\"" },
        { "name": "onQtyChange", "type": "(id: string, qty: number) => void", "required": false, "default": null, "description": "Callback when item quantity is changed" },
        { "name": "onRemove", "type": "(id: string) => void", "required": false, "default": null, "description": "Callback when an item is removed from the cart" },
        { "name": "onCheckout", "type": "() => void", "required": false, "default": null, "description": "Callback when the checkout button is clicked" },
        { "name": "open", "type": "boolean", "required": false, "default": "true", "description": "Whether the drawer is open" },
        { "name": "width", "type": "number", "required": false, "default": "380", "description": "Width of the drawer panel in pixels" },
        { "name": "bgColor", "type": "string", "required": false, "default": "theme", "description": "Background color override" },
        { "name": "textColor", "type": "string", "required": false, "default": "theme", "description": "Text color override" },
        { "name": "accentColor", "type": "string", "required": false, "default": "theme", "description": "Accent color override" },
        { "name": "borderColor", "type": "string", "required": false, "default": "theme", "description": "Border color override" },
        { "name": "fontFamily", "type": "string", "required": false, "default": "theme", "description": "Font family override" }
      ],
      "themeTokens": ["bgColor", "textColor", "accentColor", "borderColor", "fontFamily", "radius", "spacing", "cardBg", "cardRadius", "cardBorder", "inputBg", "inputText", "buttonSize"],
      "aiHints": {
