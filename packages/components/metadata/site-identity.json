    {
      "id": "siteIdentity.LogoDisplay",
      "name": "LogoDisplay",
      "description": "Logo image display with optional link wrapping. Renders a responsive brand logo that can link to any page.",
      "whenToUse": "Use on every page to display the brand logo, typically in the header. Links to the homepage by default.",
      "isShell": false,
      "props": [
        {
          "name": "src",
          "type": "string",
          "required": true,
          "default": null,
          "description": "URL or path to the logo image"
        },
        {
          "name": "alt",
          "type": "string",
          "required": false,
          "default": "\"Logo\"",
          "description": "Alt text for the logo image"
        },
        {
          "name": "width",
          "type": "number",
          "required": false,
          "default": "140",
          "description": "Width of the logo in pixels"
        },
        {
          "name": "height",
          "type": "number",
          "required": false,
          "default": "auto",
          "description": "Height of the logo in pixels (auto preserves aspect ratio)"
        },
        {
          "name": "href",
          "type": "string",
          "required": false,
          "default": null,
          "description": "Optional link URL; wraps the logo in an anchor tag when provided"
        },
        {
          "name": "bgColor",
          "type": "string",
          "required": false,
          "default": "theme",
          "description": "Background color override"
        },
        {
          "name": "textColor",
          "type": "string",
          "required": false,
          "default": "theme",
          "description": "Text color override"
        },
        {
          "name": "accentColor",
          "type": "string",
          "required": false,
          "default": "theme",
          "description": "Accent color override"
        },
        {
          "name": "borderColor",
          "type": "string",
          "required": false,
          "default": "theme",
          "description": "Border color override"
        },
        {
          "name": "fontFamily",
          "type": "string",
          "required": false,
          "default": "theme",
          "description": "Font family override"
        }
      ],
      "themeTokens": [
        "bgColor",
        "textColor",
        "accentColor",
        "borderColor",
        "fontFamily",
        "radius",
        "spacing"
