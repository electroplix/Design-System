      "description": "Main top-level navigation bar with logo, links, optional search and CTA button. Supports sticky positioning.",
      "whenToUse": "Use as the primary navigation element at the top of every page. Essential for marketing sites, dashboards, blogs, and any web app requiring consistent top-level navigation.",
      "isShell": false,
      "props": [
        { "name": "logoText", "type": "string", "required": false, "default": "\"MyBrand\"", "description": "Brand/logo text displayed in the nav bar" },
        { "name": "links", "type": "NavLink[]", "required": false, "default": "[]", "description": "Array of navigation links: {label, href}" },
        { "name": "showSearch", "type": "boolean", "required": false, "default": "false", "description": "Whether to display a search input in the nav" },
        { "name": "showCTA", "type": "boolean", "required": false, "default": "false", "description": "Whether to show the call-to-action button" },
        { "name": "ctaText", "type": "string", "required": false, "default": "\"Get Started\"", "description": "Text for the CTA button" },
        { "name": "ctaHref", "type": "string", "required": false, "default": "\"#\"", "description": "URL for the CTA button" },
