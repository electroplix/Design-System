      "whenToUse": "Use on blog post detail pages to render the full article body from HTML/rich-text content stored in a CMS.",
      "isShell": false,
      "props": [
        { "name": "html", "type": "string", "required": true, "default": null, "description": "HTML string of the article content to render" },
        { "name": "maxW", "type": "number", "required": false, "default": "720", "description": "Maximum content width in pixels for readability" },
        { "name": "bgColor", "type": "string", "required": false, "default": "theme", "description": "Background color override" },
        { "name": "textColor", "type": "string", "required": false, "default": "theme", "description": "Text color override" },
        { "name": "accentColor", "type": "string", "required": false, "default": "theme", "description": "Accent color override" },
        { "name": "borderColor", "type": "string", "required": false, "default": "theme", "description": "Border color override" },
        { "name": "fontFamily", "type": "string", "required": false, "default": "theme", "description": "Font family override" }
      ],
      "themeTokens": ["bgColor", "textColor", "accentColor", "borderColor", "fontFamily", "radius", "spacing", "cardBg", "cardRadius", "cardBorder", "tagBg", "tagColor"],
      "aiHints": {
        "pageTypes": ["blog"],
        "placement": "body",
        "priority": 9,
        "sequenceOrder": 5,
        "pairsWellWith": ["blog.AuthorByline", "blog.ReadingBar", "blog.CommentsSection", "blog.RelatedPosts"],
        "maxPerPage": 1,
        "isContainer": false
      }
    },
    {
      "id": "blog.RelatedPosts",
      "name": "RelatedPosts",
      "description": "Grid of related blog post cards shown at the end of an article. Displays a configurable title and clickable post previews.",
      "whenToUse": "Use at the bottom of blog post pages to encourage readers to explore more content. Typically placed after the article body and before comments.",
      "isShell": false,
      "props": [
        { "name": "posts", "type": "BlogPost[]", "required": true, "default": null, "description": "Array of related blog posts: {id, title, slug?, excerpt?, coverImage?, author?: {name, avatar?}, date?, readTime?, tags?, category?}" },
        { "name": "title", "type": "string", "required": false, "default": "\"Related Posts\"", "description": "Section heading text" },
        { "name": "onPostClick", "type": "(post: BlogPost) => void", "required": false, "default": null, "description": "Callback when a related post is clicked" },
        { "name": "bgColor", "type": "string", "required": false, "default": "theme", "description": "Background color override" },
        { "name": "textColor", "type": "string", "required": false, "default": "theme", "description": "Text color override" },
        { "name": "accentColor", "type": "string", "required": false, "default": "theme", "description": "Accent color override" },
        { "name": "borderColor", "type": "string", "required": false, "default": "theme", "description": "Border color override" },
        { "name": "fontFamily", "type": "string", "required": false, "default": "theme", "description": "Font family override" }
      ],
      "themeTokens": ["bgColor", "textColor", "accentColor", "borderColor", "fontFamily", "radius", "spacing", "cardBg", "cardRadius", "cardBorder", "tagBg", "tagColor"],
      "aiHints": {
        "pageTypes": ["blog"],
        "placement": "body",
        "priority": 7,
        "sequenceOrder": 8,
        "pairsWellWith": ["blog.ArticleRenderer", "blog.CommentsSection", "blog.BlogCard"],
        "maxPerPage": 1,
        "isContainer": false
      }
    },
