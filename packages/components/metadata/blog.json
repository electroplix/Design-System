      "name": "ArchiveList",
      "description": "Grouped archive list organizing blog posts by time period or category. Each group has a label and a list of post links.",
      "whenToUse": "Use on blog archive or index pages to display posts grouped by month, year, or category. Provides a structured overview of all published content.",
      "isShell": false,
      "props": [
        { "name": "groups", "type": "ArchiveGroup[]", "required": true, "default": null, "description": "Array of archive groups: {label, posts: BlogPost[]}" },
        { "name": "onPostClick", "type": "(post: BlogPost) => void", "required": false, "default": null, "description": "Callback when a post in the archive is clicked" },
        { "name": "bgColor", "type": "string", "required": false, "default": "theme", "description": "Background color override" },
        { "name": "textColor", "type": "string", "required": false, "default": "theme", "description": "Text color override" },
        { "name": "accentColor", "type": "string", "required": false, "default": "theme", "description": "Accent color override" },
        { "name": "borderColor", "type": "string", "required": false, "default": "theme", "description": "Border color override" },
        { "name": "fontFamily", "type": "string", "required": false, "default": "theme", "description": "Font family override" }
      ],
      "themeTokens": ["bgColor", "textColor", "accentColor", "borderColor", "fontFamily", "radius", "spacing", "cardBg", "cardRadius", "cardBorder", "tagBg", "tagColor"],
      "aiHints": {
        "pageTypes": ["blog"],
        "placement": "body",
        "priority": 5,
        "sequenceOrder": 7,
        "pairsWellWith": ["blog.TagList", "blog.BlogCard", "navigation.Pagination"],
        "maxPerPage": 1,
        "isContainer": false
      }
    },
