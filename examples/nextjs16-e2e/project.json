{
  "name": "nextjs16-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "examples/nextjs16-e2e/src",
  "tags": ["scope:e2e", "type:app", "framework:next16"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "examples/nextjs16-e2e"
      },
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/.next"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev -p 3099",
        "cwd": "examples/nextjs16-e2e"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start -p 3099",
        "cwd": "examples/nextjs16-e2e"
      },
      "dependsOn": ["build"]
    },
    "test:ssr": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test src/ssr-validation.mjs",
        "cwd": "examples/nextjs16-e2e"
      },
      "dependsOn": ["^build"]
    }
  }
}
