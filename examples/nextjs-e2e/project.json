{
  "name": "nextjs-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "examples/nextjs-e2e/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd examples/nextjs-e2e && npx next build",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd examples/nextjs-e2e && npx next dev -p 3099",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:ssr": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd examples/nextjs-e2e && node --test src/ssr-validation.mjs",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["^build"]
    }
  },
  "tags": ["scope:e2e", "type:app"]
}
